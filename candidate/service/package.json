{
  "name": "screening-order-service",
  "version": "1.0.0",
  "description": "Mirantus Screening Order Service",
  "author": "Babajide Williams <babanila@yahoo.com>",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "clean": "rimraf dist coverage .nyc_output",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run src --reporter=verbose",
    "test:e2e": "vitest run test --reporter=verbose",
    "test:cov": "vitest run --coverage",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate src/migrations/$npm_config_name -d src/database/datasource.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/datasource.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/datasource.ts",
    "db:test:start": "docker compose -f docker-compose.test.yml up -d",
    "db:test:wait": "docker exec screening-orders-test-db sh -c \"until pg_isready -U user -d screening_orders_test; do sleep 1; done\"",
    "db:test:migrate": "cross-env DATABASE_URL=postgresql://user:password@localhost:5432/screening_orders_test?sslmode=disable npm run migration:run",
    "db:test:stop": "docker compose -f docker-compose.test.yml down",
    "e2e": "npm run db:test:start && npm run db:test:wait && npm run db:test:migrate && npm run test:e2e",
    "e2e:clean": "npm run db:test:stop",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/typeorm": "^10.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "joi": "^17.12.0",
    "nest-winston": "^1.9.4",
    "pg": "^8.11.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "@vitest/coverage-v8": "^1.4.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "unplugin-swc": "^1.5.9",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
